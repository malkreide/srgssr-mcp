# Copy this file to .env and fill in your SRG SSR credentials.
# Register at https://developer.srgssr.ch and add the "SRG SSR PUBLIC API V2"
# product to obtain Consumer Key and Consumer Secret.

SRGSSR_CONSUMER_KEY=your-consumer-key-here
SRGSSR_CONSUMER_SECRET=your-consumer-secret-here

# Optional: log level (default: info)
# SRGSSR_LOG_LEVEL=info

# Optional: transport mode — stdio (default), sse, or streamable-http
# SRGSSR_MCP_TRANSPORT=stdio

# Optional: HTTP transport bind address (only relevant for sse / streamable-http)
# SRGSSR_MCP_HOST=127.0.0.1
# SRGSSR_MCP_PORT=8000
